# Database
DATABASE_URL=postgresql+asyncpg://clipper:clipper_pass@localhost:5432/clipper_db
DATABASE_URL_SYNC=postgresql://clipper:clipper_pass@localhost:5432/clipper_db
POSTGRES_USER=clipper
POSTGRES_PASSWORD=clipper_pass
POSTGRES_DB=clipper_db

# Redis
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# Storage
UPLOAD_DIR=/app/uploads
MEDIA_DIR=/app/media
MAX_UPLOAD_SIZE_GB=10
CHUNK_SIZE_MB=5

# Video Processing
FFMPEG_THREADS=2
WHISPER_MODEL_SIZE=base

# AI (optional)
OPENAI_API_KEY=

# App
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=false
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60
